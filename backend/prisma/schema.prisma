// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  uid   String  @id // Firebase Auth UID 
  email String  @unique
  name  String?
  role  Role    @default(USER)

  //one user has one preferences 
  notificationPreferences NotificationPreferences?
  readNotifications       UserNotificationRead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //one user has many tokens and many subscriptions
  fcmTokens          FcmToken[]
  topicSubscriptions TopicSubscription[]
  news               News[]              @relation("NewsAuthor")
  newsReactions      NewsReaction[]
  newsComments       NewsComment[]
}

model NotificationPreferences {
  id String @id @default(cuid())

  //Notification Settings
  receivePushNotifications Boolean @default(true)

  //Notification Preferences
  isMuted    Boolean   @default(false)
  mutedUntil DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [uid], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

model FcmToken {
  id       String  @id @default(cuid())
  token    String  @unique
  platform String  @default("web") // web, android, ios
  isActive Boolean @default(true) // Set to false if sending fails later

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@index([userId])
}

model Topic {
  id          String  @id @default(cuid())
  name        String  @unique //Sports, Tech, Finance
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicSubscriptions TopicSubscription[]
  newsLinks          NewsTopicLink[]
}

model TopicSubscription {
  id           String   @id @default(cuid())
  subscribedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [uid], onDelete: Cascade)

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // A user should only be able to subscribe to a specific topic once
  @@unique([userId, topicId])
  @@index([topicId])
}

model News {
  id          String  @id @default(cuid())
  title       String
  description String?
  content     String  @db.Text
  imageUrl    String?

  // Publishing workflow
  isPublished        Boolean   @default(false)
  publishedAt        DateTime?
  scheduledPublishAt DateTime?

  // Author
  authorId String?
  author   User?   @relation("NewsAuthor", fields: [authorId], references: [uid], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics         NewsTopicLink[]
  reactions      NewsReaction[]
  comments       NewsComment[]
  notification   Notification?   @relation(fields: [notificationId], references: [id])
  notificationId String?
}

model NewsTopicLink {
  newsId  String
  topicId String
  news    News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([newsId, topicId])
}

model NewsReaction {
  id   String       @id @default(cuid())
  type ReactionType

  userId String
  newsId String

  user User @relation(fields: [userId], references: [uid], onDelete: Cascade)
  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now())
  notification   Notification? @relation(fields: [notificationId], references: [id])
  notificationId String?

  @@unique([userId, newsId])
}

model NewsComment {
  id      String @id @default(cuid())
  content String

  userId String
  newsId String

  user User @relation(fields: [userId], references: [uid], onDelete: Cascade)
  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  notification   Notification? @relation(fields: [notificationId], references: [id])
  notificationId String?
}

model Notification {
  id    String @id @default(cuid())
  title String
  body  String

  //Scheduling
  sendAt       DateTime? // Null if scheduled for future
  scheduledFor DateTime? //Target time for scheduling

  sendBy      String? //ADMIN UID
  target      TargetType
  targetValue String? // UID if USER, or topicId if TOPIC
  status      NotificationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Authored news / reactions / comments
  news      News[]
  reactions NewsReaction[]
  comments  NewsComment[]

  readBy UserNotificationRead[]
}

model UserNotificationRead {
  id String @id @default(cuid())
  
  userId String
  user   User   @relation(fields: [userId], references: [uid], onDelete: Cascade)

  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  readAt DateTime @default(now())

  @@unique([userId, notificationId])
}

enum Role {
  ADMIN
  EDITOR
  USER
}

enum TargetType {
  USER
  TOPIC
  ALL
}

enum NotificationStatus {
  PENDING
  INPROGRESS
  SENT
  FAILED
}

enum ReactionType {
  LIKE
  DISLIKE
}
