# ─────────────────────────────────────────────
# Admin App Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Firebase Web App Config (same project as the user app)
# Found in: Firebase console → Project settings → Your apps → Web app → SDK setup and configuration
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=157064408547
VITE_FIREBASE_APP_ID=1:157064408547:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Backend API base URL
# Leave empty during local dev — Vite proxy routes /api → http://localhost:5000
# Set to your deployed backend URL in production, e.g. https://api.yourapp.com/api
VITE_API_URL=
